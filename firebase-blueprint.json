{
  "entities": {
    "SiteContent": {
      "title": "Site Content",
      "description": "Dynamic content for the business website",
      "type": "object",
      "properties": {
        "hero": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "about": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "User": {
      "title": "User",
      "description": "User profile with roles",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      }
    }
  },
  "firestore": {
    "/content/main": {
      "schema": "SiteContent",
      "description": "Main website content"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile"
    }
  }
}
